# =============================================================================
# Logseq AI Hub - Server Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the HTTP server listens on
PORT=3000


# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------

# API token required by the Logseq plugin to authenticate with this server
# REQUIRED - generate a strong random string (e.g. openssl rand -hex 32)
PLUGIN_API_TOKEN=your-plugin-api-token-here


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Path to the SQLite database file
DATABASE_PATH=./data/hub.sqlite


# -----------------------------------------------------------------------------
# LLM (Default provider: OpenRouter - https://openrouter.ai)
# -----------------------------------------------------------------------------

# API key for your LLM provider (OpenRouter or OpenAI-compatible)
LLM_API_KEY=your-llm-api-key-here

# Alternatively, set OPENROUTER_API_KEY (takes precedence if both are set)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Base URL for the LLM API endpoint (OpenRouter default shown)
LLM_ENDPOINT=https://openrouter.ai/api/v1

# Model identifier to use for agent requests
AGENT_MODEL=anthropic/claude-sonnet-4

# Timeout in milliseconds for a single LLM request
AGENT_REQUEST_TIMEOUT=30000

# Optional: HTTP Referer sent to OpenRouter (used for leaderboard ranking)
# LLM_HTTP_REFERER=https://your-app-domain.com

# Optional: App title sent to OpenRouter (used for leaderboard ranking)
# LLM_TITLE=Logseq AI Hub


# -----------------------------------------------------------------------------
# Messaging (WhatsApp / Telegram)
# -----------------------------------------------------------------------------

# WhatsApp Cloud API - verify token for webhook validation
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token-here

# WhatsApp Cloud API - access token for sending messages
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here

# WhatsApp Cloud API - phone number ID
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id-here

# Telegram Bot API token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here


# -----------------------------------------------------------------------------
# Events
# -----------------------------------------------------------------------------

# Number of days to retain hub events before purging
EVENT_RETENTION_DAYS=30

# Maximum number of messages to keep per session
SESSION_MESSAGE_LIMIT=50

# Maximum number of items returned by list endpoints
LIST_LIMIT_MAX=100


# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Secret used to validate incoming webhook signatures
WEBHOOK_SECRET=your-webhook-secret-here

# JSON array of allowed HTTP origins / IPs for the allowlist (default: allow all)
# Example: ["https://trusted-origin.com","https://another-origin.com"]
HTTP_ALLOWLIST=[]
