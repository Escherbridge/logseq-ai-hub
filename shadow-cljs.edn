;; shadow-cljs configuration
{:source-paths
 ["src/main" "src/test" "src/dev"]

 :dependencies
 []

 :dev-http {8080 "./"}

 :nrepl        {:port 8702}

 :builds
 {:app
  {:target :browser
   :output-dir "./"
   :modules {:main {:init-fn logseq-ai-hub.core/init}}
   }

  :node-test {:target :node-test
              :output-to "out/test/node-tests.js"
              :ns-regexp ".*-test$"}}

 }
